# Copy this file to ".env" in the same folder and edit the values.
# .env is never sent to the browser — only this server process reads it.

PORT=3000

# Credentials required to log in as admin (add/view-as-admin access).
# Change these before letting anyone else use the server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

USER_USERNAME=user
USER_PASSWORD=user123

# Used to sign login tokens. Set this to a long random string.
JWT_SECRET=change-this-to-a-long-random-string

# How long an admin login stays valid before they must log in again.
TOKEN_EXPIRY=12h
